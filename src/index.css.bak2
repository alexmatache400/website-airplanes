/* Navigation Light Blinking */
@keyframes nav-light-blink {
  0%, 50% {
    opacity: 1;
  }
  51%, 100% {
    opacity: 0.3;
  }
}

/* Radar Sweep Effect */
@keyframes radar-sweep {
  0% {
    box-shadow: 0 0 0 0 rgba(232, 244, 248, 0.5);
  }
  70% {
    box-shadow: 0 0 0 8px rgba(232, 244, 248, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(232, 244, 248, 0);
  }
}

/* Flight Path Classes - Disabled */
.flight-path {
  display: none;
}

/* Aircraft Classes */
.aircraft {
  position: absolute;
  opacity: 0;
  z-index: 10;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
}

.aircraft-1 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-1 12s ease-in-out infinite;
  animation-delay: 2s, 3s;
}

.aircraft-2 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-2 11s ease-in-out infinite;
  animation-delay: 4s, 5s;
}

.aircraft-3 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-3 15s ease-in-out infinite;
  animation-delay: 6s, 7s;
}

.aircraft-4 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-4 9s ease-in-out infinite;
  animation-delay: 8s, 9s;
}

.aircraft-5 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-5 12s ease-in-out infinite;
  animation-delay: 10s, 11s;
}

.aircraft-6 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-6 8s ease-in-out infinite;
  animation-delay: 3s, 4s;
}

.aircraft-7 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-7 7s ease-in-out infinite;
  animation-delay: 5s, 6s;
}

.aircraft-8 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-8 10s ease-in-out infinite;
  animation-delay: 7s, 8s;
}

.aircraft-9 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-9 14s ease-in-out infinite;
  animation-delay: 1s, 2s;
}

.aircraft-10 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-10 9s ease-in-out infinite;
  animation-delay: 9s, 10s;
}

.aircraft-11 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-11 8s ease-in-out infinite;
  animation-delay: 4s, 5s;
}

.aircraft-12 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-12 7s ease-in-out infinite;
  animation-delay: 6s, 7s;
}

.aircraft-13 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-13 10s ease-in-out infinite;
  animation-delay: 8s, 9s;
}

.aircraft-14 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-14 8s ease-in-out infinite;
  animation-delay: 2s, 3s;
}

.aircraft-15 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-15 16s ease-in-out infinite;
  animation-delay: 5s, 6s;
}

.aircraft-16 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-16 11s ease-in-out infinite;
  animation-delay: 7s, 8s;
}

.aircraft-17 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-17 6s ease-in-out infinite;
  animation-delay: 3s, 4s;
}

.aircraft-18 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-18 12s ease-in-out infinite;
  animation-delay: 9s, 10s;
}

.aircraft-19 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-19 10s ease-in-out infinite;
  animation-delay: 1s, 2s;
}

.aircraft-20 {
  animation: aircraft-spawn 2s ease-out forwards, flight-route-20 13s ease-in-out infinite;
  animation-delay: 6s, 7s;
}

/* Navigation Light Effects */
.aircraft svg circle[fill="#ffd700"] {
  animation: nav-light-blink 2s infinite;
}

.aircraft svg circle[fill="#ff4444"] {
  animation: nav-light-blink 1.5s infinite;
}

.aircraft svg circle[fill="#44ff44"] {
  animation: nav-light-blink 1.8s infinite;
}

/* Hover Radar Effect */
.aircraft:hover {
  animation-name: radar-sweep;
  animation-duration: 2s;
  animation-iteration-count: infinite;
}

/* Flight Tracker Panel Counter Animation */
.counter {
  transition: all 0.3s ease;
}

/* Glass Panel Enhancement */
.flight-tracker-panel {
  background: rgba(20, 30, 48, 0.85);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

/* Responsive Parallax for Page Scroll */
.air-traffic-container {
  transform-style: preserve-3d;
}

@media (max-width: 768px) {
  .aircraft {
    transform: scale(0.8);
  }

  .flight-tracker-panel {
    min-width: auto;
    width: 240px;
  }
}

/* Product Pulse Animation for Search Highlight */
@keyframes productPulse {
  0% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(56, 189, 248, 0.45);
  }
  40% {
    transform: scale(1.02);
    box-shadow: 0 0 0 12px rgba(56, 189, 248, 0);
  }
  60% {
    transform: scale(1.015);
    box-shadow: 0 0 0 6px rgba(56, 189, 248, 0.15);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(56, 189, 248, 0);
  }
}

.pulse-5s {
  animation: productPulse 5s ease-in-out 1;
}

/* Light Mode Theme Overrides */
.light {
  /* CSS Variables for Light Mode */
  --bg: #ffffff;
  --bg-muted: #f8fafc;
  --card: #ffffff;
  --card-muted: #f9fafb;
  --border: #e5e7eb;
  --shadow: 0 1px 2px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.06);

  --text: #0f172a;
  --text-muted: #475569;
  --text-subtle: #64748b;

  --primary: #0a84ff;
  --primary-fore: #ffffff;
  --accent: #111827;
  --link: #1d4ed8;
  --link-hover: #1e40af;

  --focus: #2563eb;

  /* Text colors */
  --tw-prose-body: #374151;
  --tw-prose-headings: #111827;
  --tw-prose-links: #3b82f6;

  /* Dropdown components (Light Mode - WCAG AA Compliant) */
  --dropdown-bg: #ffffff;
  --dropdown-text: #0f172a;           /* slate-900 - 16.37:1 contrast */
  --dropdown-border: #9ca3af;         /* gray-400 - visible but subtle */
  --dropdown-hover-bg: #f3f4f6;       /* gray-100 */
  --dropdown-focus-ring: #2563eb;     /* blue-600 */

  --dropdown-placeholder: #6b7280;    /* gray-500 - 4.61:1 contrast */
  --dropdown-caret: #374151;          /* gray-700 */

  --dropdown-menu-bg: #ffffff;
  --dropdown-menu-border: #d1d5db;    /* gray-300 */
  --dropdown-menu-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.05);

  --dropdown-option-default: #0f172a;        /* slate-900 */
  --dropdown-option-hover-bg: #f3f4f6;       /* gray-100 */
  --dropdown-option-hover-text: #0f172a;     /* slate-900 */
  --dropdown-option-selected-bg: #2563eb;    /* blue-600 */
  --dropdown-option-selected-text: #ffffff;
  --dropdown-option-disabled: #9ca3af;       /* gray-400 */
}

/* Light mode text color overrides - High contrast for readability */
.light .text-dark-100 {
  color: #0f172a !important;
}

.light .text-dark-200 {
  color: #1e293b !important;
}

.light .text-dark-300 {
  color: #334155 !important;
}

.light .text-dark-400 {
  color: #475569 !important;
}

.light .text-white {
  color: #0f172a !important;
}

.light .text-slate-400 {
  color: #475569 !important;
}

/* Light mode background overrides */
.light .bg-dark-950 {
  background-color: #f9fafb !important;
}

.light .bg-dark-900 {
  background-color: #ffffff !important;
}

.light .bg-dark-800 {
  background-color: #f3f4f6 !important;
}

.light .bg-dark-700 {
  background-color: #e5e7eb !important;
}

.light .bg-slate-800 {
  background-color: #ffffff !important;
  border-width: 2px !important;
}

.light .bg-slate-700 {
  background-color: #f3f4f6 !important;
}

/* Light mode border overrides */
.light .border-dark-700 {
  border-color: #d1d5db !important;
}

.light .border-dark-600 {
  border-color: #9ca3af !important;
}

.light .border-slate-700 {
  border-color: #d1d5db !important;
}

/* Light mode hover states */
.light .hover\:bg-dark-700:hover {
  background-color: #e5e7eb !important;
}

.light .hover\:bg-dark-800:hover {
  background-color: #f3f4f6 !important;
}

.light .hover\:bg-slate-700\/70:hover {
  background-color: #f3f4f6 !important;
}

.light .hover\:text-accent-400:hover {
  color: #1d4ed8 !important;
}

.light .hover\:text-accent-300:hover {
  color: #1e3a8a !important;
}

.light .hover\:text-dark-100:hover {
  color: #0f172a !important;
}

/* Light mode backgrounds with opacity - Higher opacity for readability */
.light [class*="bg-dark-900/"] {
  background-color: rgba(255, 255, 255, 0.95) !important;
  box-shadow: var(--shadow);
}

.light [class*="bg-dark-800/"] {
  background-color: rgba(255, 255, 255, 0.9) !important;
  backdrop-filter: blur(8px);
  box-shadow: var(--shadow);
}

.light [class*="bg-dark-700/"] {
  background-color: rgba(243, 244, 246, 0.9) !important;
}

.light [class*="bg-slate-800/"] {
  background-color: rgba(255, 255, 255, 0.95) !important;
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
}

.light [class*="bg-slate-700/"] {
  background-color: rgba(243, 244, 246, 0.9) !important;
}

/* Light mode gradient overlays */
.light .bg-dark-950\/85 {
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.4)) !important;
}

/* Light mode focus rings */
.light .focus\:ring-sky-500:focus {
  --tw-ring-color: #2563eb !important;
}

.light .focus\:ring-accent-500:focus {
  --tw-ring-color: #2563eb !important;
}

/* Light mode buttons */
.light .bg-accent-500 {
  background-color: #2563eb !important;
  color: #ffffff !important;
}

.light .hover\:bg-accent-600:hover {
  background-color: #1d4ed8 !important;
}

/* Light mode selected states */
.light .bg-sky-500 {
  background-color: #0f172a !important;
  color: #ffffff !important;
}

.light .shadow-sky-500\/50 {
  box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.3), 0 4px 6px -4px rgba(15, 23, 42, 0.2);
}

/* Light mode link colors */
.light a {
  color: var(--link);
}

.light a:hover {
  color: var(--link-hover);
}
