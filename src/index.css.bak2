@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');
@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  /* Semantic CSS Variables for Dropdown Components (Dark Mode Default) */
  :root {
    /* Dropdown control */
    --dropdown-bg: #1e293b;           /* slate-800 */
    --dropdown-text: #f1f5f9;         /* slate-100 */
    --dropdown-border: #334155;       /* slate-700 */
    --dropdown-hover-bg: #334155;     /* slate-700 */
    --dropdown-focus-ring: #0ea5e9;   /* sky-500 */

    /* Dropdown placeholder & caret */
    --dropdown-placeholder: #94a3b8;  /* slate-400 */
    --dropdown-caret: #cbd5e1;        /* slate-300 */

    /* Dropdown menu panel */
    --dropdown-menu-bg: #1e293b;      /* slate-800 */
    --dropdown-menu-border: #475569;  /* slate-600 */
    --dropdown-menu-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -4px rgba(0, 0, 0, 0.3);

    /* Dropdown option states */
    --dropdown-option-default: #f1f5f9;    /* slate-100 */
    --dropdown-option-hover-bg: #334155;   /* slate-700 */
    --dropdown-option-hover-text: #f8fafc; /* slate-50 */
    --dropdown-option-selected-bg: #0ea5e9; /* sky-500 */
    --dropdown-option-selected-text: #ffffff;
    --dropdown-option-disabled: #64748b;   /* slate-500 */
  }

  body {
    @apply bg-dark-950 text-dark-100 font-sans;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Light mode styles */
  .light body {
    @apply bg-transparent text-gray-900;
  }

  code {
    @apply font-mono;
  }
}

@layer utilities {
  .glass {
    @apply bg-dark-900/60 backdrop-blur-lg border border-dark-700/50;
  }

  .glass-light {
    @apply bg-dark-800/40 backdrop-blur-md border border-dark-600/30;
  }

  /* Light mode glass effects */
  .light .glass {
    @apply bg-white/80 backdrop-blur-lg border border-gray-200;
  }

  .light .glass-light {
    @apply bg-white/60 backdrop-blur-md border border-gray-300/50;
  }
}

/* Cinematic Air Traffic System */

/* Map Parallax and Zoom */
@keyframes map-breathing {
  0%, 100% {
    transform: scale(1) translateX(0);
  }
  50% {
    transform: scale(1.02) translateX(-2px);
  }
}

.air-traffic-container {
  animation: map-breathing 30s ease-in-out infinite;
}

/* Flight Path Progressive Drawing */
@keyframes flight-path-appear {
  0% {
    stroke-dasharray: 0, 2000;
    opacity: 0;
  }
  30% {
    opacity: 0.8;
  }
  100% {
    stroke-dasharray: 2000, 0;
    opacity: 0.8;
  }
}

@keyframes flight-path-disappear {
  0% {
    opacity: 0.8;
  }
  100% {
    opacity: 0;
  }
}

/* Aircraft Takeoff Sequences */
@keyframes aircraft-spawn {
  0% {
    opacity: 0;
    transform: scale(0.3) rotate(0deg);
  }
  30% {
    opacity: 0.7;
    transform: scale(0.8) rotate(0deg);
  }
  100% {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }
}

/* Realistic Flight Routes */

/* Route 1: NYC → London (Transatlantic) */
@keyframes flight-route-1 {
  0% {
    left: 30.2%;
    top: 29.6%;
    transform: rotate(45deg);
    opacity: 0;
  }
  3% {
    opacity: 1;
  }
  25% {
    left: 40%;
    top: 25%;
    transform: rotate(35deg);
  }
  50% {
    left: 50%;
    top: 22%;
    transform: rotate(25deg);
  }
  75% {
